@startuml
skinparam activity {
  BackgroundColor #FEF9E7
  BorderColor #F39C12
  FontColor #2C3E50
}
skinparam condition {
  BackgroundColor #E8F8F5
  BorderColor #1ABC9C
}

start

:Customer выбирает блюда;
:Добавление в корзину (addToCart);

if (Проверка доступности ингредиентов?) then (да)
  :Расчёт суммы заказа;
  :Выбор способа оплаты;
  :Выбор адреса доставки;
  
  if (Оплата успешна?) then (да)
    :Создание заказа (Order);
    :Уведомление ресторана;
    
    if (RestaurantManager подтверждает?) then (да)
      :Статус: Cooking;
      :Приготовление блюд;
      :Статус: Ready;
      :Назначение курьера;
      
      if (Courier принимает заказ?) then (да)
        :Статус: OnDelivery;
        :Отслеживание маршрута;
        :Доставка клиенту;
        :Статус: Delivered;
        :Возможность оставить отзыв;
        stop
      else (нет)
        :Поиск другого курьера;
        if (Курьер найден?) then (да)
          :Назначение курьера;
          :Статус: OnDelivery;
          :Доставка клиенту;
          stop
        else (нет)
          :Отмена заказа;
          :Возврат средств;
          stop
        endif
      endif
    else (нет)
      :Отклонение заказа;
      :Возврат средств;
      stop
    endif
  else (нет)
    :Ошибка оплаты;
    :Предложение повторить;
    stop
  endif
else (нет)
  :Уведомление о недоступности;
  :Предложение альтернатив;
  stop
endif

@enduml