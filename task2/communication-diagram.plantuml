@startuml
skinparam linetype ortho
skinparam sequenceMessageAlign center

participant "Customer" as C
participant "Order" as O
participant "Payment" as P
participant "Restaurant" as R
participant "Courier" as D
participant "Notification" as N

C -> O: placeOrder(items, address)
activate O
O -> P: processPayment(amount)
activate P
P --> O: paymentConfirmed(transactionId)
deactivate P

O -> R: notifyNewOrder(orderDetails)
activate R
R --> O: orderConfirmed(estimatedTime)
deactivate R

O -> D: assignDelivery(route)
activate D
D --> O: deliveryAccepted(eta)
deactivate D

O -> N: sendConfirmation(customerId)
activate N
N --> C: orderConfirmedMessage()
deactivate N

O --> C: orderDetailsWithTracking()
deactivate O

@enduml