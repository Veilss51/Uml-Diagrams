@startuml
skinparam backgroundColor White
skinparam BorderColor Black
skinparam ArrowColor Black
skinparam class {
  BackgroundColor White
  BorderColor Black
  FontColor Black
}

interface "Order" as OrderInterface {
  +getCost(): decimal
  +getDescription(): string
  +calculateDeliveryTime(): int
}

class "BasicOrder" as Basic {
  -items: List<MenuItem>
  -baseAddress: string
  -customerId: int
  +getCost(): decimal
  +getDescription(): string
  +calculateDeliveryTime(): int
}

abstract class "OrderDecorator" as Decorator {
  #wrappedOrder: Order
  +getCost(): decimal
  +getDescription(): string
  +calculateDeliveryTime(): int
}

class "UrgentDeliveryDecorator" as Urgent {
  -urgentFee: decimal
  -priorityLevel: int
  +getCost(): decimal
  +getDescription(): string
  +calculateDeliveryTime(): int
  -prioritizeInQueue(): void
}

class "GiftPackagingDecorator" as Gift {
  -packagingFee: decimal
  -giftMessage: string
  +getCost(): decimal
  +getDescription(): string
  +wrapGift(): void
}

class "TemperatureControlDecorator" as Temp {
  -tempFee: decimal
  -tempType: string
  +getCost(): decimal
  +getDescription(): string
  +maintainTemperature(): void
}

OrderInterface <|-- Basic
OrderInterface <|-- Decorator

Decorator o-- OrderInterface : wraps/delegates

Decorator <|-- Urgent
Decorator <|-- Gift
Decorator <|-- Temp

note right of Basic
  Базовый заказ
  Только еда и стандартная доставка
end note

note right of Urgent
  Добавляет поведение:
  - Срочность
  - Приоритет курьеру
  - Доплата за скорость
end note

note right of Gift
  Добавляет поведение:
  - Упаковка
  - Открытка
  - Доплата за упаковку
end note

note right of Temp
  Добавляет поведение:
  - Термоупаковка
  - Поддержание температуры
  - Доплата за термо
end note

note bottom of Decorator
  Ключевая идея:
  Мы не создаем классы вида
  "UrgentGiftTempOrder".
  Мы динамически оборачиваем
  BasicOrder нужными декораторами.
end note

@enduml
